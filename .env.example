# HubSpot API — same token as Unified Dashboard (get from Railway env vars)
HUBSPOT_ACCESS_TOKEN=

# Dashboard password — required. Set this in Railway environment variables.
# Any visitor hitting the app will be prompted for this password.
# Session persists for 7 days via a secure HTTP-only cookie.
DASHBOARD_PASSWORD=your-secret-password-here

# Server
PORT=3000
NODE_ENV=development

# Database (optional — only needed if using PostgreSQL cache)
DATABASE_URL=
